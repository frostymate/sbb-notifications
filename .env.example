# How often to poll Google Calendar (seconds) — adapts automatically:
#   idle (no trip soon): POLL_IDLE
#   trip within 2h: POLL_APPROACHING
#   active journey: POLL_ACTIVE
POLL_IDLE=300
POLL_APPROACHING=120
POLL_ACTIVE=30

# How many minutes before a stop/transfer to notify
NOTIFY_MINUTES_BEFORE=2

# Google Calendar ID (usually "primary" for your main calendar)
GOOGLE_CALENDAR_ID=primary

# Path to Google OAuth credentials JSON (downloaded from Google Cloud Console)
GOOGLE_CREDENTIALS_FILE=credentials.json

# Notification backend: "native" (notify-send/osascript) or "plyer"
NOTIFICATION_BACKEND=native

# Timezone (IANA format)
TIMEZONE=Europe/Zurich
